rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Allow read and write access for all authenticated users.
      // In a production app, you should restrict this further.
      allow read, write: if request.auth != null;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    // Public read access for all files
    match /{allPaths=**} {
      allow read: if true;
    }

    // Allow uploads for logged-in users to specific paths
    match /recordings/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /assessment-images/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow anyone to upload to the "uploads" folder for testing
    match /uploads/{allPaths=**} {
      allow write: if true;
    }
  }
}
