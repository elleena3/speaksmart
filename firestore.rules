
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read and write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Authenticated users can read assessments, but only the creator can write them.
    match /assessments/{assessmentId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // Authenticated users can create their own results.
    // They can read, update, or delete results they own.
    // The teacher who created the assessment can also read the results.
    match /results/{resultId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.teacherUid);
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    // Allow read/write access to files in the 'recordings' folder for authenticated users.
    // The path wildcard allows for sub-folder structures like recordings/userId/assessmentId.
    match /recordings/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /assessment-images/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
