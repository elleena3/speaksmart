rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to write to the recordings folder
    match /recordings/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to write to the test-uploads folder for diagnostics
    match /test-uploads/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
