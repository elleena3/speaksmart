
rules_version = '2';

// See: https://firebase.google.com/docs/storage/security
service firebase.storage {
  match /b/{bucket}/o {
    // A more permissive rule for initial development and testing.
    // This allows any user to read and write to Storage.
    // For production, you should restrict access based on authentication.
    // e.g., `allow read, write: if request.auth != null;`
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
