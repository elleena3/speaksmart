
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // 유저 ID로 폴더를 구분하여, 해당 유저만 자신의 폴더에 접근 가능하게 합니다.
    // 보안 강화를 위해 권장되는 규칙입니다.
    // 예: /b/bucket-name/o/user_files/user_id_123/my_file.jpg
    match /user_files/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 현재 애플리케이션의 업로드 경로를 위한 규칙입니다.
    // 인증된 모든 사용자가 recordings 폴더에 파일을 쓸 수 있도록 허용합니다.
    match /recordings/{allPaths=**} {
       allow read, write: if request.auth != null;
    }
    
    // 이미지 파일 업로드 경로를 위한 규칙입니다.
    match /assessment-images/{allPaths=**} {
       allow read, write: if request.auth != null;
    }

    // 기타 업로드 경로를 위한 규칙입니다.
     match /uploads/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
