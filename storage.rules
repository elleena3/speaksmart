rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Match any file in the 'recordings' folder
    match /recordings/{fileName} {
      // Helper function to get the user ID from the filename
      // Assumes filename format is: {userId}_...
      function getUserIdFromFilename() {
        return fileName.split('_')[0];
      }

      // Allow read and write access only if the requesting user's ID
      // matches the user ID in the filename.
      // This ensures users can only access their own recordings.
      allow read, write: if request.auth != null && request.auth.uid == getUserIdFromFilename();
    }
  }
}
